      "condition": "formula.validation_status == verified",
      "description": "Verified wiki math flows to training with domain tag"
    },
    "rsmv_cache_formats_to_megatron": {
      "enabled": true,
      "condition": "parser/metadata extraction only",
      "description": "RuneScape cache format metadata and parser structure extracted to training corpus"
    },
    "schematics_diagrams_to_megatron": {
      "enabled": true,
      "condition": "image metadata/captions only",
      "description": "Schema names, file paths, and document metadata into training corpus"
    },
    "voice_assets_to_megatron": {
      "enabled": false,
      "condition": "needs audio transcription",
      "description": "Disabled until audio transcription pipeline exists"
    },
    "godhead_models_to_megatron": {
      "enabled": true,
      "condition": "manifest metadata only",
      "description": "Model manifest data only, not full binary weights"
    },
    "open_design_backend_to_megatron": {
      "enabled": true,
      "condition": "code/doc metadata only",
      "description": "Route/service metadata into training corpus"
    },
    "openjarvis_skills_to_megatron": {
      "enabled": true,
      "condition": "skill metadata only",
      "description": "Skill titles/paths/metadata into training corpus"
    },
    "megatron_pretrain_to_megatron": {
      "enabled": true,
      "condition": "always",
      "description": "Existing pretrain manifests merged into final corpus"
    },
    "pog2_capture_to_megatron": {
      "enabled": true,
      "condition": "image/document metadata only",
      "description": "POG2 capture metadata into training corpus"
    },
    "rsmv_model_identity_kit_to_megatron": {
      "enabled": true,
      "condition": "metadata/extraction only; no raw binary weights",
      "description": "Model identity kit metadata and timestamped manifests into training corpus"
